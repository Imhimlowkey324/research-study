# --- Generated data (keep the folder, ignore its contents) ---
data/*
!data/.gitkeep

# --- Jupyter ---
.ipynb_checkpoints/

# --- Secrets / environment variables ---
.env
*.env

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp

# --- OS cruft ---
.DS_Store
Thumbs.db
