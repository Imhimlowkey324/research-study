# --- Virtual environments ---
.venv/
venv/
env/

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class

# --- Packaging / build artifacts ---
build/
dist/
*.egg-info/
.eggs/

# --- Testing & coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
